{
  "manifest_version": 3,
  "name": "VoxRead",
  "version": "1.0.0",
  "description": "Convert any webpage into natural-sounding audio instantly",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
  "16": "icons/icons8-audio-16.png",
  "48": "icons/icons8-audio-48.png"
},
  "host_permissions": [
  "https://voxread-backend.onrender.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/Readability.js"],
      "matches": ["<all_urls>"]
    }
  ]
}